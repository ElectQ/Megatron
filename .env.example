# Megatron Environment Configuration
# 复制为 .env 后填写真实值。不要把真实 .env 提交到仓库。

# 运行环境
MEGATRON_ENV=development
MEGATRON_BASE_URL=http://localhost:8000

# 数据库
# 本地默认可继续使用 SQLite；生产环境建议切换 PostgreSQL。
MEGATRON_DATABASE_URL=sqlite+aiosqlite:///./megatron.db
# MEGATRON_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/megatron

# 安全
# 下面三项生产环境必须替换为强随机值。
MEGATRON_ADMIN_TOKEN=change-me-admin-token
MEGATRON_SESSION_SECRET=change-me-session-secret
MEGATRON_MASTER_KEY=change-me-master-key
MEGATRON_ADMIN_PASSWORD=Ch@ngeMe#2024!Secure

# 数据接入
INGEST_TOKEN=ingest-local-dev-token
SOUNDWAVE_REPO_URL=https://github.com/ElectQ/Soundwave.git
