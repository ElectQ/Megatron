# Megatron 配置
# 这个文件是可选的 —— 所有项都有默认值,可以直接删掉此文件用默认配置跑。
# 所有运行时 secrets(LLM API key、webhook token、用户密码)存在数据库里。

# 环境与安全
MEGATRON_ENV=development
MEGATRON_ADMIN_TOKEN=admin-local-dev-token
MEGATRON_SESSION_SECRET=change-me-to-a-long-random-string-for-session

# 数据库(可选,默认 ./megatron.db)
DATABASE_URL=sqlite+aiosqlite:///./megatron.db

# 数据接入(可选,Soundwave 拉模式需要)
INGEST_TOKEN=ingest-local-dev-token
SOUNDWAVE_REPO_URL=https://github.com/ElectQ/Soundwave.git

# 服务地址(可选,默认 http://localhost:8000)
BASE_URL=http://localhost:8000
