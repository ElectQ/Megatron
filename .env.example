# Megatron v0.1.0
# 复制为 .env，deploy.sh 会自动生成密码

# 数据库 (默认 SQLite，无需改动)
DATABASE_URL=sqlite+aiosqlite:///./app/data/megatron.db

# 安全 (deploy.sh 自动生成，手动部署需自行填写)
MEGATRON_SESSION_SECRET=
MEGATRON_ADMIN_PASSWORD=

# LLM (必填)
MEGATRON_DEEPSEEK_API_KEY=

# 钉钉推送 (可选)
MEGATRON_DINGTALK_URL=
MEGATRON_DINGTALK_SECRET=

# 端口 (可选，默认 8000)
PORT=8000
