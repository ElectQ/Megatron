# Megatron v0.1.0
# 复制为 .env，deploy.sh 会自动生成密码
#
# 注意：所有 Megatron 的配置项都必须带 MEGATRON_ 前缀，没有前缀的变量会被忽略。

# 数据库 (默认 SQLite)
# 四条斜杠 = 绝对路径 /app/data/megatron.db（挂载卷上）。
# 三条斜杠是相对 WORKDIR=/app 的路径，会落到卷外面，容器重建即丢数据。
MEGATRON_DATABASE_URL=sqlite+aiosqlite:////app/data/megatron.db

# 安全 (deploy.sh 自动生成；留空则首次启动自动生成并持久化到 /app/data/)
MEGATRON_SESSION_SECRET=
MEGATRON_ADMIN_PASSWORD=

# 采集源推送 (Collector → Megatron 的 Bearer token，见 docs/使用指南.md「源接入」)
MEGATRON_INGEST_TOKEN=

# 【必填】读者实际访问这个实例的地址。推送里的「查看今日详情」链接是用它拼出来的，
# 填 localhost/127.0.0.1 的话，推到手机上的那条链接点开就是死的。
# MEGATRON_ENV=prod 时如果是回环地址，服务会直接拒绝启动（宁可起不来，也不要连发一周死链）。
# 例：https://megatron.example.com 或 http://<公网IP>:8000
MEGATRON_BASE_URL=

# MCP 实时拉取开关：off | backfill | always
# backfill = 仅当当日库里 0 条时才用 MCP 补库，然后照常从库读（过渡期默认）
# 等 Soundwave 改为 HTTP Push 后改成 off
MEGATRON_MCP_LIVE_FETCH=backfill

# 兼容用：git_pull 源的仓库地址 (可选)
MEGATRON_SOUNDWAVE_REPO_URL=

# LLM (必填)
MEGATRON_DEEPSEEK_API_KEY=

# 钉钉推送 (可选)
MEGATRON_DINGTALK_URL=
MEGATRON_DINGTALK_SECRET=

# 端口 (可选，默认 8000)
PORT=8000
